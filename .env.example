# Copie este arquivo para .env.local e preencha com as credenciais do Firebase.
# As credenciais aparecem em: Firebase Console → Configurações do projeto → Seus apps → SDK do Firebase (config)

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
