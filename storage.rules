rules_version = '2';

// Regras do Firebase Storage.
// - /candidatos/{candidatoId}/...  currículos e relatórios de entrevista.
//   Qualquer usuário autenticado pode ler; RH e Gestor podem escrever.
//   (validação fina de "gestor da vaga" é feita no Firestore — aqui só
//   restringimos a usuários logados para evitar acesso público direto.)

service firebase.storage {
  match /b/{bucket}/o {
    match /candidatos/{candidatoId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 20 * 1024 * 1024;  // 20 MB max
    }
    // Foto de perfil + documentos digitalizados dos prestadores (DP).
    // Qualquer usuário autenticado pode ler/escrever — a granularidade
    // (RH x Gestor) é feita no Firestore na hora de gravar a referência.
    match /prestadores/{prestadorId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 20 * 1024 * 1024;  // 20 MB max
    }
  }
}
