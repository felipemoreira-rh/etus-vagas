rules_version = '2';

// Regras de segurança do Firestore para o sistema ETUS Vagas.
// Modelo (2 módulos integrados):
//   - users/{uid}:              perfil do usuário (role: "rh" | "gestor").
//   - vagas/{id}:               vagas abertas pelos gestores (módulo RH).
//   - candidatos/{id}:          candidatos em processo seletivo (módulo RH).
//   - onboarding/{id}:          checklist de integração de novos contratados (módulo RH).
//   - estagiarios/{id}:         estagiários ativos/finalizados (módulo DP).
//   - colaboradores/{id}:       colaboradores e período de experiência (módulo DP).

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isRh() {
      return isSignedIn() && myRole() == 'rh';
    }

    function isGestor() {
      return isSignedIn() && myRole() == 'gestor';
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (
        (request.auth.uid == uid &&
          request.resource.data.role == resource.data.role) ||
        isRh()
      );
      allow delete: if isRh();
    }

    match /vagas/{vagaId} {
      allow read: if isRh() ||
                     (isGestor() && resource.data.gestorUid == request.auth.uid);
      allow create: if (isRh() ||
                        (isGestor() && request.resource.data.gestorUid == request.auth.uid)) &&
                       request.resource.data.status == 'aberta';
      // Gestor pode atualizar a própria vaga (incluindo mudar status) desde
      // que mantenha gestorUid intacto. RH pode tudo.
      allow update: if isRh() ||
                       (isGestor() &&
                        resource.data.gestorUid == request.auth.uid &&
                        request.resource.data.gestorUid == resource.data.gestorUid);
      allow delete: if isRh();
    }

    // === Módulo RH ===
    // Candidatos: RH lê/escreve tudo. Gestor pode ler os candidatos vinculados
    // a uma vaga de sua responsabilidade (via vagaGestorUid).
    match /candidatos/{id} {
      allow read: if isRh() ||
                     (isGestor() && resource.data.vagaGestorUid == request.auth.uid);
      allow create, delete: if isRh();
      // Gestor pode atualizar candidatos das próprias vagas (mover fase, anotar).
      // RH pode tudo. Em ambos os casos, vagaGestorUid não pode ser alterado.
      allow update: if isRh() ||
                       (isGestor() &&
                        resource.data.vagaGestorUid == request.auth.uid &&
                        request.resource.data.vagaGestorUid == resource.data.vagaGestorUid);
    }

    match /onboarding/{id} {
      allow read, write: if isRh();
    }

    // === Módulo DP — Departamento Pessoal ===
    match /estagiarios/{id} {
      allow read, write: if isRh();
    }

    match /colaboradores/{id} {
      allow read, write: if isRh();
    }
  }
}
